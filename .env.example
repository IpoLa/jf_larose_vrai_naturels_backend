DATABASE_URL="mysql://root:password@localhost:3306/les_vrais_naturels"

# Optional DB overrides (useful when DATABASE_URL has docker-internal host like db)
# DATABASE_HOST_OVERRIDE=127.0.0.1
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USER=root
# DB_USERNAME=root
# DB_PASSWORD=password
# DB_NAME=les_vrais_naturels
# DB_DATABASE=les_vrais_naturels
# DB_CONNECTION_LIMIT=15

JWT_SECRET="change-me-to-a-long-random-secret"
PORT=3001
CLIENT_BASE_URL="http://localhost:3000"
ADMIN_BASE_URL="http://localhost:5173"
ALLOWED_ORIGINS="http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173"

# Emergency switch (do not enable in normal production usage)
# CORS_ALLOW_ALL=false
