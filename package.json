{
  "name": "les-vrais-naturels-backend",
  "version": "1.0.0",
  "description": "Backend API - Les Vrais Naturels - JF Larose",
  "main": "dist/main.js",
  "scripts": {
    "build": "prisma generate && tsc --build tsconfig.build.json && npm run build:seed",
    "build:seed": "npx tsc prisma/seed.ts --outDir dist/prisma --module commonjs --esModuleInterop --moduleResolution node --target ES2023 --skipLibCheck 2>/dev/null || true",
    "start": "node dist/main.js",
    "start:dev": "npx nest start --watch",
    "start:debug": "npx nest start --debug --watch",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:push": "prisma db push",
    "prisma:seed": "node dist/prisma/seed.js",
    "prisma:seed:dev": "ts-node prisma/seed.ts",
    "deploy:prepare": "npm run build && npm prune --omit=dev"
  },
  "prisma": {
    "seed": "node dist/prisma/seed.js"
  },
  "dependencies": {
    "@nestjs/common": "^10.2.10",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^10.2.10",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/mapped-types": "^2.0.2",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.2.10",
    "@nestjs/swagger": "^7.1.14",
    "@prisma/adapter-mariadb": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "mysql2": "^3.18.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.1.14",
    "rxjs": "^7.8.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/testing": "^10.2.10",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/node": "^20.15.1",
    "@types/passport-jwt": "^3.0.13",
    "@types/qrcode": "^1.5.5",
    "@types/uuid": "^9.0.7",
    "prisma": "^7.4.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
