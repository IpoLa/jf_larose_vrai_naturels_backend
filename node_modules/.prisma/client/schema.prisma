// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"] // ← enables driver adapter API
  engineType      = "none"
}

datasource db {
  provider = "mysql"
  //  url      = env("DATABASE_URL")

  // Use MariaDB adapter for optimized performance on cPanel
  // Install: npm install @prisma/adapter-mariadb
  // Docs: https://www.prisma.io/docs/orm/overview/databases/mariadb
}

model AdminUser {
  id           String   @id @default(uuid())
  phone        String   @unique
  passwordHash String
  name         String
  role         String   @default("admin")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("admin_users")
}

model Pharmacy {
  id        String   @id @default(uuid())
  name      String
  address   String?
  phone     String?
  region    String?
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vendors Vendor[]

  @@map("pharmacies")
}

model Vendor {
  id                String   @id @default(uuid())
  uniqueCardNumber  String   @unique
  name              String?
  email             String?
  phone             String?
  ccp               String?
  ccpKey            String?
  rip               String?
  pharmacyId        String?
  status            String   @default("active")
  actionDate        DateTime @default(now())
  registrationBonus Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  pharmacy       Pharmacy?            @relation(fields: [pharmacyId], references: [id])
  sales          Sale[]
  paymentPeriods PaymentPeriod[]
  qrCodes        QrCode[]
  notifications  VendorNotification[]

  @@map("vendors")
}

model Delegue {
  id               String   @id @default(uuid())
  uniqueCardNumber String   @unique
  name             String
  email            String?
  phone            String?
  region           Json
  sector           String?
  status           String   @default("active")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  qrCodes       DelegueQrCode[]
  notifications DelegueNotification[]

  @@map("delegues")
}

model DelegueQrCode {
  id          String   @id @default(uuid())
  delegueId   String
  uniqueKey   String   @unique
  qrUrl       String
  qrImageData String?  @db.LongText
  generatedAt DateTime @default(now())
  isActive    Boolean  @default(true)

  delegue Delegue @relation(fields: [delegueId], references: [id])

  @@map("delegue_qr_codes")
}

model Product {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  indication  String
  description String?
  argumentKey String?
  whyItWorks  String?
  imageUrl    String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sales Sale[]

  @@map("products")
}

model Sale {
  id          String   @id @default(uuid())
  vendorId    String
  productId   String?
  productName String
  quantity    Int
  unitPrice   Float    @default(0)
  saleDate    DateTime @default(now())
  periodId    String?

  vendor  Vendor         @relation(fields: [vendorId], references: [id])
  product Product?       @relation(fields: [productId], references: [id])
  period  PaymentPeriod? @relation(fields: [periodId], references: [id])

  createdAt DateTime @default(now())

  @@map("sales")
}

model PaymentPeriod {
  id              String    @id @default(uuid())
  vendorId        String
  periodType      String
  startDate       DateTime
  endDate         DateTime
  totalSales      Int       @default(0)
  totalCommission Float     @default(0)
  status          String    @default("pending")
  paidAt          DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  vendor Vendor @relation(fields: [vendorId], references: [id])
  sales  Sale[]

  @@map("payment_periods")
}

model CommissionRule {
  id                   String   @id @default(uuid())
  periodType           String
  quantityFrom         Int
  quantityTo           Int?
  commissionPerProduct Float
  bonusPerProduct      Float    @default(0)
  label                String?
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@map("commission_rules")
}

model QrCode {
  id          String   @id @default(uuid())
  vendorId    String
  uniqueKey   String   @unique
  qrUrl       String
  qrImageData String?  @db.LongText
  generatedAt DateTime @default(now())
  isActive    Boolean  @default(true)

  vendor Vendor @relation(fields: [vendorId], references: [id])

  @@map("qr_codes")
}

model Notification {
  id         String   @id @default(uuid())
  title      String
  message    String
  type       String   @default("info")
  targetType String   @default("all")
  createdAt  DateTime @default(now())

  vendorNotifications  VendorNotification[]
  delegueNotifications DelegueNotification[]

  @@map("notifications")
}

model VendorNotification {
  id             String    @id @default(uuid())
  notificationId String
  vendorId       String
  isRead         Boolean   @default(false)
  readAt         DateTime?

  notification Notification @relation(fields: [notificationId], references: [id])
  vendor       Vendor       @relation(fields: [vendorId], references: [id])

  @@unique([notificationId, vendorId])
  @@map("vendor_notifications")
}

model DelegueNotification {
  id             String    @id @default(uuid())
  notificationId String
  delegueId      String
  isRead         Boolean   @default(false)
  readAt         DateTime?

  notification Notification @relation(fields: [notificationId], references: [id])
  delegue      Delegue      @relation(fields: [delegueId], references: [id])

  @@unique([notificationId, delegueId])
  @@map("delegue_notifications")
}
